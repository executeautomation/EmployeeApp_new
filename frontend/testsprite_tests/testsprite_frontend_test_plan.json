  {
    "id": "TC001",
    "title": "Successful login navigates user to Employee List",
    "description": "Verifies that a user can log in with valid credentials and is routed to the employee list page.",
    "category": "User Login",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Login\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the username input field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password input field"
      },
      {
        "type": "action",
        "description": "Click the Login button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/list\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Employee List\" is visible"
      }
    ]
  },
